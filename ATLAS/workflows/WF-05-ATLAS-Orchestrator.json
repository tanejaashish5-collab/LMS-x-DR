        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM atlas_agent_logs WHERE created_at > CURRENT_DATE - INTERVAL '1 day' ORDER BY created_at DESC LIMIT 50;",
        "additionalFields": {}
      },
      "id": "get-logs",

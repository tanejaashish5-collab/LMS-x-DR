          "id": "1",
          "name": "ATLAS Supabase"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM atlas_budget_summary WHERE month_key = TO_CHAR(CURRENT_DATE, 'YYYY-MM');",
        "additionalFields": {}
      },
      "id": "get-budget",
      "name": "Get Budget Status",
      "type": "n8n-nodes-base.supabase",

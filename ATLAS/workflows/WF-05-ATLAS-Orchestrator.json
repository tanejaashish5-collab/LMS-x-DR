        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM atlas_opportunities WHERE status = 'sonnet_scored' AND scored_at > CURRENT_DATE - INTERVAL '1 day';",
        "additionalFields": {}
      },
      "id": "get-opportunities",
      "name": "Get New Opportunities",
      "type": "n8n-nodes-base.supabase",
